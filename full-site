<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Jupiter Healthcare and Chiropractic | Spinal Decompression & Trusted Care in Jupiter, FL</title>
<meta name="description" content="Jupiter Healthcare and Chiropractic offers spinal decompression, chiropractic adjustments, massage therapy, and cold laser therapy in Jupiter, FL. Led by Dr. James McErlain, D.C.">
<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,400;0,500;0,600;0,700;1,400;1,500&family=Outfit:wght@300;400;500;600;700&display=swap" rel="stylesheet">
<style>

/* SVG fallback sizing */
svg { max-width: 100%; }
svg:not([width]) { width: 24px; height: 24px; }
/* ===== RESET & VARIABLES ===== */
*, *::before, *::after { margin: 0; padding: 0; box-sizing: border-box; }

:root {
  --navy: #0B1D32;
  --blue-deep: #133C65;
  --blue-primary: #1A5FA0;
  --blue-bright: #2B7EC6;
  --blue-light: #E6F0FA;
  --blue-pale: #F2F7FC;
  --gold: #C8993E;
  --gold-light: #E8D5A8;
  --white: #FFFFFF;
  --gray-50: #F8FAFB;
  --gray-100: #EEF1F4;
  --gray-200: #D8DEE5;
  --gray-400: #8E99A8;
  --gray-600: #5A6577;
  --gray-800: #2D3444;
  --gray-900: #1A1F2B;
  --font-display: 'Cormorant Garamond', Georgia, serif;
  --font-body: 'Outfit', -apple-system, sans-serif;
  --shadow-sm: 0 1px 3px rgba(11,29,50,0.06), 0 1px 2px rgba(11,29,50,0.04);
  --shadow-md: 0 4px 16px rgba(11,29,50,0.08), 0 2px 6px rgba(11,29,50,0.04);
  --shadow-lg: 0 12px 40px rgba(11,29,50,0.1), 0 4px 12px rgba(11,29,50,0.06);
  --shadow-xl: 0 20px 60px rgba(11,29,50,0.12), 0 8px 20px rgba(11,29,50,0.06);
  --radius-sm: 6px;
  --radius-md: 12px;
  --radius-lg: 20px;
  --radius-xl: 32px;
  --transition: 0.3s cubic-bezier(0.4, 0, 0.2, 1);
}

html { scroll-behavior: smooth; scroll-padding-top: 80px; }

body {
  font-family: var(--font-body);
  color: var(--gray-800);
  line-height: 1.65;
  font-weight: 400;
  background: var(--white);
  overflow-x: hidden;
  -webkit-font-smoothing: antialiased;
}

img { max-width: 100%; height: auto; display: block; }
a { text-decoration: none; color: inherit; }
button { cursor: pointer; border: none; background: none; font-family: inherit; }

/* ===== TYPOGRAPHY ===== */
h1, h2, h3, h4 { font-family: var(--font-display); font-weight: 600; line-height: 1.2; color: var(--navy); }
h1 { font-size: clamp(2.5rem, 5vw, 4rem); letter-spacing: -0.01em; }
h2 { font-size: clamp(2rem, 4vw, 3rem); }
h3 { font-size: clamp(1.4rem, 2.5vw, 1.75rem); }
h4 { font-size: 1.2rem; }
p { font-size: 1.05rem; color: var(--gray-600); }

.section-label {
  font-family: var(--font-body);
  font-size: 0.8rem;
  font-weight: 600;
  letter-spacing: 0.15em;
  text-transform: uppercase;
  color: var(--blue-primary);
  margin-bottom: 0.75rem;
  display: block;
}

.section-title { margin-bottom: 1.25rem; }
.section-subtitle { font-size: 1.15rem; color: var(--gray-600); max-width: 640px; line-height: 1.7; }

/* ===== LAYOUT ===== */
.container { width: 100%; max-width: 1200px; margin: 0 auto; padding: 0 24px; }
.section-padding { padding: 100px 0; }

/* ===== BUTTONS ===== */
.btn {
  display: inline-flex;
  align-items: center;
  gap: 8px;
  padding: 14px 32px;
  border-radius: 50px;
  font-family: var(--font-body);
  font-size: 0.95rem;
  font-weight: 600;
  letter-spacing: 0.02em;
  transition: all var(--transition);
  white-space: nowrap;
}

.btn-primary {
  background: var(--blue-primary);
  color: var(--white);
  box-shadow: 0 4px 16px rgba(26,95,160,0.3);
}
.btn-primary:hover {
  background: var(--blue-bright);
  box-shadow: 0 6px 24px rgba(26,95,160,0.4);
  transform: translateY(-2px);
}

.btn-secondary {
  background: var(--white);
  color: var(--blue-primary);
  border: 2px solid var(--blue-primary);
}
.btn-secondary:hover {
  background: var(--blue-primary);
  color: var(--white);
  transform: translateY(-2px);
}

.btn-gold {
  background: var(--gold);
  color: var(--white);
  box-shadow: 0 4px 16px rgba(200,153,62,0.3);
}
.btn-gold:hover {
  background: #b8892e;
  box-shadow: 0 6px 24px rgba(200,153,62,0.4);
  transform: translateY(-2px);
}

.btn-white {
  background: var(--white);
  color: var(--navy);
  box-shadow: var(--shadow-md);
}
.btn-white:hover {
  transform: translateY(-2px);
  box-shadow: var(--shadow-lg);
}

/* ===== NAVIGATION ===== */
.nav {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  z-index: 1000;
  background: rgba(255,255,255,0.92);
  backdrop-filter: blur(20px);
  -webkit-backdrop-filter: blur(20px);
  border-bottom: 1px solid rgba(11,29,50,0.06);
  transition: all var(--transition);
}
.nav.scrolled {
  box-shadow: var(--shadow-md);
}
.nav-inner {
  display: flex;
  align-items: center;
  justify-content: space-between;
  height: 76px;
}
.nav-logo {
  display: flex;
  align-items: center;
  gap: 12px;
}
.nav-logo img {
  height: 48px;
  width: auto;
}
.nav-logo-text {
  font-family: var(--font-display);
  font-size: 1.25rem;
  font-weight: 600;
  color: var(--navy);
  line-height: 1.2;
}
.nav-logo-text span {
  display: block;
  font-size: 0.7rem;
  font-family: var(--font-body);
  font-weight: 500;
  color: var(--blue-primary);
  letter-spacing: 0.08em;
  text-transform: uppercase;
}
.nav-links {
  display: flex;
  align-items: center;
  gap: 32px;
  list-style: none;
}
.nav-links a {
  font-size: 0.9rem;
  font-weight: 500;
  color: var(--gray-600);
  transition: color var(--transition);
  position: relative;
}
.nav-links a::after {
  content: '';
  position: absolute;
  bottom: -4px;
  left: 0;
  width: 0;
  height: 2px;
  background: var(--blue-primary);
  transition: width var(--transition);
}
.nav-links a:hover { color: var(--blue-primary); }
.nav-links a:hover::after { width: 100%; }
.nav-links a.active { color: var(--blue-primary); }
.nav-links a.active::after { width: 100%; }
.nav-cta {
  display: flex;
  align-items: center;
  gap: 16px;
}
.nav-phone {
  font-size: 0.9rem;
  font-weight: 600;
  color: var(--navy);
  display: flex;
  align-items: center;
  gap: 6px;
}
.nav-phone svg { width: 16px; height: 16px; color: var(--blue-primary); }

/* Mobile menu */
.nav-toggle {
  display: none;
  flex-direction: column;
  gap: 5px;
  padding: 8px;
}
.nav-toggle span {
  display: block;
  width: 24px;
  height: 2px;
  background: var(--navy);
  transition: all var(--transition);
  border-radius: 2px;
}

/* ===== HERO ===== */
.hero {
  position: relative;
  min-height: 92vh;
  display: flex;
  align-items: center;
  padding-top: 76px;
  overflow: hidden;
  background: linear-gradient(135deg, var(--blue-pale) 0%, var(--white) 40%, var(--blue-pale) 100%);
}
.hero::before {
  content: '';
  position: absolute;
  top: -200px;
  right: -200px;
  width: 700px;
  height: 700px;
  border-radius: 50%;
  background: radial-gradient(circle, rgba(26,95,160,0.06) 0%, transparent 70%);
  pointer-events: none;
}
.hero::after {
  content: '';
  position: absolute;
  bottom: -100px;
  left: -100px;
  width: 400px;
  height: 400px;
  border-radius: 50%;
  background: radial-gradient(circle, rgba(200,153,62,0.05) 0%, transparent 70%);
  pointer-events: none;
}
.hero-inner {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 60px;
  align-items: center;
}
.hero-content { position: relative; z-index: 2; }
.hero-badge {
  display: inline-flex;
  align-items: center;
  gap: 8px;
  background: var(--white);
  border: 1px solid var(--gray-100);
  border-radius: 50px;
  padding: 8px 18px;
  font-size: 0.82rem;
  font-weight: 500;
  color: var(--gray-600);
  margin-bottom: 28px;
  box-shadow: var(--shadow-sm);
}
.hero-badge svg { width: 16px; height: 16px; color: var(--gold); }
.hero h1 {
  margin-bottom: 20px;
}
.hero h1 em {
  font-style: italic;
  color: var(--blue-primary);
}
.hero-desc {
  font-size: 1.15rem;
  line-height: 1.75;
  color: var(--gray-600);
  margin-bottom: 36px;
  max-width: 520px;
}
.hero-buttons { display: flex; gap: 16px; flex-wrap: wrap; margin-bottom: 48px; }
.hero-stats {
  display: flex;
  gap: 40px;
}
.hero-stat {
  text-align: left;
}
.hero-stat-number {
  font-family: var(--font-display);
  font-size: 2.2rem;
  font-weight: 700;
  color: var(--navy);
  line-height: 1;
  margin-bottom: 4px;
}
.hero-stat-label {
  font-size: 0.82rem;
  color: var(--gray-400);
  font-weight: 500;
}
.hero-visual {
  position: relative;
  z-index: 2;
}
.hero-image-wrapper {
  position: relative;
  border-radius: var(--radius-xl);
  overflow: hidden;
  box-shadow: var(--shadow-xl);
  aspect-ratio: 4/5;
}
.hero-image-wrapper img {
  width: 100%;
  height: 100%;
  object-fit: cover;
}
.hero-floating-card {
  position: absolute;
  bottom: 24px;
  left: -32px;
  background: var(--white);
  border-radius: var(--radius-md);
  padding: 18px 22px;
  box-shadow: var(--shadow-lg);
  display: flex;
  align-items: center;
  gap: 14px;
  z-index: 3;
  animation: float 4s ease-in-out infinite;
}
@keyframes float {
  0%, 100% { transform: translateY(0); }
  50% { transform: translateY(-8px); }
}
.hero-floating-icon {
  width: 44px;
  height: 44px;
  border-radius: 50%;
  background: var(--blue-light);
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}
.hero-floating-icon svg { width: 22px; height: 22px; color: var(--blue-primary); }
.hero-floating-text {
  font-size: 0.85rem;
  font-weight: 600;
  color: var(--navy);
  line-height: 1.3;
}
.hero-floating-text span {
  display: block;
  font-weight: 400;
  font-size: 0.78rem;
  color: var(--gray-400);
}

/* ===== TRUST BAR ===== */
.trust-bar {
  padding: 40px 0;
  background: var(--white);
  border-bottom: 1px solid var(--gray-100);
}
.trust-items {
  display: flex;
  justify-content: center;
  align-items: center;
  gap: 48px;
  flex-wrap: wrap;
}
.trust-item {
  display: flex;
  align-items: center;
  gap: 10px;
  font-size: 0.9rem;
  font-weight: 500;
  color: var(--gray-600);
}
.trust-item svg { width: 20px; height: 20px; color: var(--blue-primary); flex-shrink: 0; }

/* ===== SERVICES ===== */
.services { background: var(--gray-50); }
.services-header {
  text-align: center;
  margin-bottom: 64px;
}
.services-header .section-subtitle { margin: 0 auto; }
.services-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 28px;
}
.service-card {
  background: var(--white);
  border-radius: var(--radius-lg);
  overflow: hidden;
  box-shadow: var(--shadow-sm);
  transition: all var(--transition);
  border: 1px solid var(--gray-100);
}
.service-card:hover {
  transform: translateY(-6px);
  box-shadow: var(--shadow-lg);
  border-color: transparent;
}
.service-card-img {
  height: 200px;
  overflow: hidden;
  position: relative;
}
.service-card-img img {
  width: 100%;
  height: 100%;
  object-fit: cover;
  transition: transform 0.6s ease;
}
.service-card:hover .service-card-img img {
  transform: scale(1.06);
}
.service-card-body {
  padding: 28px;
}
.service-card-body h3 {
  font-size: 1.3rem;
  margin-bottom: 12px;
}
.service-card-body p {
  font-size: 0.95rem;
  line-height: 1.65;
  color: var(--gray-600);
}
.service-tag {
  display: inline-block;
  font-size: 0.72rem;
  font-weight: 600;
  letter-spacing: 0.1em;
  text-transform: uppercase;
  color: var(--blue-primary);
  background: var(--blue-light);
  padding: 5px 12px;
  border-radius: 50px;
  margin-bottom: 14px;
}

/* ===== CONDITIONS ===== */
.conditions-inner {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 80px;
  align-items: start;
}
.conditions-left { position: sticky; top: 120px; }
.conditions-left .section-subtitle { margin-bottom: 28px; }
.conditions-grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 16px;
}
.condition-item {
  display: flex;
  align-items: flex-start;
  gap: 12px;
  padding: 18px 20px;
  background: var(--blue-pale);
  border-radius: var(--radius-md);
  transition: all var(--transition);
  border: 1px solid transparent;
}
.condition-item:hover {
  background: var(--white);
  border-color: var(--blue-primary);
  box-shadow: var(--shadow-sm);
}
.condition-icon {
  width: 36px;
  height: 36px;
  border-radius: 50%;
  background: var(--blue-primary);
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}
.condition-icon svg { width: 18px; height: 18px; color: var(--white); }
.condition-item h4 {
  font-family: var(--font-body);
  font-size: 0.95rem;
  font-weight: 600;
  color: var(--navy);
  margin-bottom: 3px;
}
.condition-item p {
  font-size: 0.82rem;
  color: var(--gray-400);
  line-height: 1.5;
}

/* ===== ABOUT / TEAM ===== */
.about { background: var(--gray-50); }
.about-header { text-align: center; margin-bottom: 64px; }
.about-header .section-subtitle { margin: 0 auto; }
.about-grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 60px;
  align-items: start;
  margin-bottom: 80px;
}
.about-image {
  border-radius: var(--radius-xl);
  overflow: hidden;
  box-shadow: var(--shadow-lg);
  position: relative;
}
.about-image img {
  width: 100%;
  aspect-ratio: 3/4;
  object-fit: cover;
  object-position: top center;
}
.about-content h3 { margin-bottom: 16px; }
.about-content p {
  margin-bottom: 16px;
  font-size: 1rem;
  line-height: 1.75;
}
.about-credentials {
  display: flex;
  flex-wrap: wrap;
  gap: 10px;
  margin-top: 24px;
}
.credential-tag {
  font-size: 0.8rem;
  font-weight: 500;
  padding: 6px 14px;
  background: var(--blue-light);
  color: var(--blue-primary);
  border-radius: 50px;
}

/* Why choose us */
.why-grid {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: 24px;
  margin-top: 64px;
}
.why-card {
  text-align: center;
  padding: 36px 24px;
  background: var(--white);
  border-radius: var(--radius-lg);
  border: 1px solid var(--gray-100);
  transition: all var(--transition);
}
.why-card:hover {
  border-color: var(--blue-primary);
  box-shadow: var(--shadow-md);
  transform: translateY(-4px);
}
.why-icon {
  width: 56px;
  height: 56px;
  border-radius: 50%;
  background: var(--blue-light);
  display: flex;
  align-items: center;
  justify-content: center;
  margin: 0 auto 18px;
}
.why-icon svg { width: 26px; height: 26px; color: var(--blue-primary); }
.why-card h4 {
  font-family: var(--font-body);
  font-size: 1rem;
  font-weight: 600;
  color: var(--navy);
  margin-bottom: 8px;
}
.why-card p {
  font-size: 0.88rem;
  color: var(--gray-400);
  line-height: 1.6;
}

/* Office info bar */
.office-info {
  margin-top: 64px;
  background: var(--navy);
  border-radius: var(--radius-lg);
  padding: 48px;
  display: grid;
  grid-template-columns: 1fr 1fr 1fr;
  gap: 40px;
}
.office-info-block h4 {
  font-family: var(--font-body);
  font-size: 0.8rem;
  font-weight: 600;
  letter-spacing: 0.12em;
  text-transform: uppercase;
  color: var(--gold);
  margin-bottom: 16px;
}
.office-info-block p,
.office-info-block li {
  color: rgba(255,255,255,0.75);
  font-size: 0.92rem;
  line-height: 1.8;
}
.office-info-block ul { list-style: none; }

/* ===== TESTIMONIALS ===== */
.testimonials-header { text-align: center; margin-bottom: 56px; }
.testimonials-header .section-subtitle { margin: 0 auto; }
.rating-summary {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 12px;
  margin-top: 20px;
}
.rating-stars { display: flex; gap: 4px; }
.rating-stars svg { width: 22px; height: 22px; color: var(--gold); fill: var(--gold); }
.rating-text { font-size: 1rem; font-weight: 600; color: var(--navy); }
.rating-count { font-size: 0.9rem; color: var(--gray-400); }

.testimonials-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 24px;
  margin-bottom: 56px;
}
.testimonial-card {
  background: var(--white);
  border-radius: var(--radius-lg);
  padding: 32px;
  border: 1px solid var(--gray-100);
  box-shadow: var(--shadow-sm);
  transition: all var(--transition);
  position: relative;
}
.testimonial-card:hover {
  box-shadow: var(--shadow-md);
  transform: translateY(-3px);
}
.testimonial-card::before {
  content: '\201C';
  font-family: var(--font-display);
  font-size: 4rem;
  color: var(--blue-light);
  position: absolute;
  top: 16px;
  left: 28px;
  line-height: 1;
}
.testimonial-stars {
  display: flex;
  gap: 3px;
  margin-bottom: 16px;
}
.testimonial-stars svg { width: 16px; height: 16px; color: var(--gold); fill: var(--gold); }
.testimonial-text {
  font-size: 0.95rem;
  line-height: 1.7;
  color: var(--gray-600);
  margin-bottom: 20px;
  position: relative;
  z-index: 1;
}
.testimonial-author {
  display: flex;
  align-items: center;
  gap: 12px;
}
.testimonial-avatar {
  width: 40px;
  height: 40px;
  border-radius: 50%;
  background: var(--blue-light);
  display: flex;
  align-items: center;
  justify-content: center;
  font-family: var(--font-display);
  font-size: 1.1rem;
  font-weight: 700;
  color: var(--blue-primary);
}
.testimonial-author-info h4 {
  font-family: var(--font-body);
  font-size: 0.9rem;
  font-weight: 600;
  color: var(--navy);
}
.testimonial-author-info span {
  font-size: 0.78rem;
  color: var(--gray-400);
}

/* Featured testimonial */
.featured-testimonial {
  background: linear-gradient(135deg, var(--blue-deep) 0%, var(--navy) 100%);
  border-radius: var(--radius-xl);
  padding: 56px 64px;
  position: relative;
  overflow: hidden;
}
.featured-testimonial::before {
  content: '';
  position: absolute;
  top: -100px;
  right: -100px;
  width: 300px;
  height: 300px;
  border-radius: 50%;
  background: rgba(200,153,62,0.08);
}
.featured-testimonial blockquote {
  font-family: var(--font-display);
  font-size: 1.4rem;
  font-style: italic;
  color: rgba(255,255,255,0.9);
  line-height: 1.6;
  margin-bottom: 24px;
  position: relative;
  z-index: 1;
}
.featured-testimonial .testimonial-author-info h4 { color: var(--white); }
.featured-testimonial .testimonial-author-info span { color: rgba(255,255,255,0.5); }
.featured-testimonial .testimonial-avatar {
  background: rgba(255,255,255,0.15);
  color: var(--gold);
}

/* ===== SPECIAL OFFER BANNER ===== */
.offer-banner {
  background: linear-gradient(135deg, var(--gold) 0%, #b8892e 100%);
  position: relative;
  overflow: hidden;
}
.offer-banner::before {
  content: '';
  position: absolute;
  inset: 0;
  background: url('data:image/svg+xml,<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 100 100" width="24" height="24"><circle cx="20" cy="30" r="40" fill="rgba(255,255,255,0.04)"/><circle cx="80" cy="70" r="50" fill="rgba(255,255,255,0.03)"/></svg>');
  background-size: cover;
}
.offer-inner {
  display: flex;
  align-items: center;
  justify-content: space-between;
